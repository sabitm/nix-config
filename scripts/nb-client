#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: nb-client <host> <nixos-rebuild args> [--user <user>]"
  echo "  Example: nb-client lbox switch --flake /home/sabit/nix-config#base"
  echo "           nb-client lbox switch --flake /home/sabit/nix-config#base --user john"
  exit 1
}

if [[ $# -lt 2 ]]; then
  usage
fi

HOST="$1"
shift
USER="sabit"

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --user)
      USER="$2"
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

BUILDER="ssh-ng://${USER}@${HOST} x86_64-linux,aarch64-linux - 4 1 nixos-test,benchmark,big-parallel,kvm"
SUBSTITUTER="ssh-ng://${USER}@${HOST}"

if ! ssh -o ConnectTimeout=5 -o BatchMode=yes "${USER}@${HOST}" true 2>/dev/null; then
  echo "Cannot reach ${USER}@${HOST}. Run 'nb-host start' on the host first."
  exit 1
fi

sudo nixos-rebuild "${args[@]}" \
  --builders "$BUILDER" \
  --use-remote-sudo \
  --option extra-substituters "$SUBSTITUTER" \
  --option trusted-substituters "$SUBSTITUTER"
